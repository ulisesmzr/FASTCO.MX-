{%- comment -%}
  ─────────────────────────────────────────
  fastco-footer.liquid
  Footer institucional fastco.
  Wordmark + 4 columnas + slogan + bottom bar.
  Sprint 2026-05-06.
  ─────────────────────────────────────────
{%- endcomment -%}

{{ 'section-fastco-footer.css' | asset_url | stylesheet_tag }}

<footer class="fastco-footer">

  <div class="fastco-footer-main">
    <div class="fastco-footer-inner">

      {%- comment -%} BRAND COLUMN {%- endcomment -%}
      <div class="fastco-footer-brand">
        <a href="{{ routes.root_url }}" class="fastco-footer-logo" aria-label="fastco">
          <span class="fastco-footer-logo-mark">fastco</span><span class="fastco-footer-logo-dot">.</span>
        </a>
        <p class="fastco-footer-tagline">
Distribuidor B2B de suministros HORECA institucional. Marcas líderes con respaldo y entrega 48h en CDMX y zona metropolitana.
        </p>
        <div class="fastco-footer-social">
          <a href="#" aria-label="LinkedIn fastco" class="fastco-social-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="#" aria-label="Instagram fastco" class="fastco-social-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.4a4 4 0 1 1-7.9 1 4 4 0 0 1 7.9-1z"/><circle cx="17.5" cy="6.5" r="0.5" fill="currentColor"/></svg>
          </a>
          <a href="#" aria-label="WhatsApp fastco" class="fastco-social-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M21 11.5a8.4 8.4 0 0 1-1.2 4.4 8.5 8.5 0 0 1-7.3 4.1 8.4 8.4 0 0 1-4-1L3 21l1.9-5.4a8.4 8.4 0 0 1-1-4 8.5 8.5 0 0 1 4.1-7.3 8.4 8.4 0 0 1 4.4-1.2h.5a8.5 8.5 0 0 1 8 8z"/></svg>
          </a>
        </div>
      </div>

      {%- comment -%} CATÁLOGO column {%- endcomment -%}
      <div class="fastco-footer-col">
        <h4 class="fastco-footer-col-title">Catálogo</h4>
        <ul class="fastco-footer-col-list">
          <li><a href="/collections/higienico-institucional">Higiénico institucional</a></li>
          <li><a href="/collections/toalla-de-manos">Toalla de manos</a></li>
          <li><a href="/collections/servilletas-y-manteleria">Servilletas y mantelería</a></li>
          <li><a href="/collections/dispensadores">Dispensadores</a></li>
          <li><a href="/collections/limpieza-y-quimicos">Limpieza y químicos</a></li>
          <li><a href="/collections/epp-y-desechables">EPP y desechables</a></li>
          <li><a href="/collections/refacciones-rapidas">Refacciones rápidas</a></li>
        </ul>
      </div>

      {%- comment -%} EMPRESA column {%- endcomment -%}
      <div class="fastco-footer-col">
        <h4 class="fastco-footer-col-title">Empresa</h4>
        <ul class="fastco-footer-col-list">
          <li><a href="/pages/quienes-somos">Quiénes somos</a></li>
          <li><a href="/pages/logistica">Logística y cobertura</a></li>
          <li><a href="/pages/marcas">Marcas que distribuimos</a></li>
          <li><a href="/pages/contacto">Contacto</a></li>
        </ul>
      </div>

      {%- comment -%} CONTACTO column {%- endcomment -%}
      <div class="fastco-footer-col">
        <h4 class="fastco-footer-col-title">Contacto</h4>
        <ul class="fastco-footer-col-list fastco-footer-col-list--contact">
          <li>
            <span class="fastco-footer-contact-label">Atención general</span>
            <a href="mailto:hola@fastco.mx">hola@fastco.mx</a>
          </li>
          <li>
            <span class="fastco-footer-contact-label">Horario</span>
            Lun – Vie · 9:00 – 18:00<br>
            Sáb · 10:00 – 14:00
          </li>
          <li>
            <span class="fastco-footer-contact-label">Cobertura</span>
            CDMX y zona metropolitana<br>
            Nacional vía Estafeta y DHL
          </li>
        </ul>
      </div>

    </div>
  </div>

  {%- comment -%} SLOGAN STRIP {%- endcomment -%}
  <div class="fastco-footer-slogan">
    <div class="fastco-footer-slogan-inner">
      <span class="fastco-footer-slogan-text">Tu operación nunca se detiene<span class="fastco-footer-slogan-dot">.</span></span>
    </div>
  </div>

  {%- comment -%} BOTTOM BAR {%- endcomment -%}
  <div class="fastco-footer-bottom">
    <div class="fastco-footer-bottom-inner">
      <div class="fastco-footer-bottom-left">
        <span>© {{ 'now' | date: '%Y' }} fastco · Todos los derechos reservados</span>
      </div>
      <div class="fastco-footer-bottom-right">
        <a href="/policies/privacy-policy">Aviso de privacidad</a>
        <a href="/policies/terms-of-service">Términos y condiciones</a>
        <a href="/policies/refund-policy">Devoluciones</a>
        <a href="/policies/shipping-policy">Envíos</a>
      </div>
    </div>
  </div>

</footer>

{% schema %}
{
  "name": "fastco · Footer",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Configuración del footer fastco"
    },
    {
      "type": "paragraph",
      "content": "Footer institucional con 4 columnas, slogan y bottom bar. Editable en código (sections/fastco-footer.liquid)."
    }
  ],
  "presets": [
    {
      "name": "fastco · Footer"
    }
  ]
}
{% endschema %}
