{%- comment -%}
  ─────────────────────────────────────────
  fastco-bestsellers.liquid
  Vitrina de productos destacados desde una
  colección configurable en el editor.
  Sprint 2026-05-06.
  ─────────────────────────────────────────
{%- endcomment -%}

{{ 'section-fastco-bestsellers.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign coll = collections[section.settings.collection]
  assign limit = section.settings.product_count | default: 8
-%}

<section class="fastco-bestsellers" data-section-id="{{ section.id }}">
  <div class="fastco-bestsellers-inner">

    <header class="fastco-bestsellers-head">
      <div class="fastco-bestsellers-head-text">
        {%- if section.settings.eyebrow != blank -%}
          <div class="fastco-section-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class="fastco-section-title">{{ section.settings.title }}</h2>
        {%- endif -%}
        {%- if section.settings.lead != blank -%}
          <p class="fastco-section-lead">{{ section.settings.lead }}</p>
        {%- endif -%}
      </div>

      {%- if section.settings.show_view_all and coll != blank -%}
        <a href="{{ coll.url }}" class="fastco-bestsellers-viewall">
          Ver todos
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </header>

    {%- if coll != blank and coll.products_count > 0 -%}

      <div class="fastco-bestsellers-grid">
        {%- for product in coll.products limit: limit -%}
          <a href="{{ product.url }}" class="fastco-product-card">

            <div class="fastco-product-card-media">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.featured_image.alt | escape | default: product.title }}"
                  width="600"
                  height="600"
                  loading="lazy"
                  class="fastco-product-card-img"
                >
              {%- else -%}
                <div class="fastco-product-card-img fastco-product-card-img--empty" aria-hidden="true">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
                </div>
              {%- endif -%}

              {%- if product.compare_at_price > product.price -%}
                <span class="fastco-product-card-tag fastco-product-card-tag--sale">Oferta</span>
              {%- elsif product.tags contains 'eco' -%}
                <span class="fastco-product-card-tag fastco-product-card-tag--eco">Eco</span>
              {%- elsif product.available == false -%}
                <span class="fastco-product-card-tag fastco-product-card-tag--out">Agotado</span>
              {%- endif -%}
            </div>

            <div class="fastco-product-card-body">
              {%- if product.vendor != blank -%}
                <div class="fastco-product-card-vendor">{{ product.vendor }}</div>
              {%- endif -%}

              <h3 class="fastco-product-card-title">{{ product.title }}</h3>

              <div class="fastco-product-card-price-row">
                {%- if product.compare_at_price > product.price -%}
                  <span class="fastco-product-card-price">{{ product.price | money_with_currency }}</span>
                  <span class="fastco-product-card-compare">{{ product.compare_at_price | money }}</span>
                {%- else -%}
                  <span class="fastco-product-card-price">{{ product.price | money_with_currency }}</span>
                {%- endif -%}
              </div>
            </div>

          </a>
        {%- endfor -%}
      </div>

    {%- else -%}

      {%- comment -%} Estado vacío — instructivo para Ulises en preview {%- endcomment -%}
      <div class="fastco-bestsellers-empty">
        <div class="fastco-bestsellers-empty-icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
        </div>
        <h3 class="fastco-bestsellers-empty-title">Esta sección está esperando productos</h3>
        <p class="fastco-bestsellers-empty-desc">
          Asigna una colección con productos activos en el editor (Customize → fastco · Bestsellers → Colección). Mientras los productos estén en DRAFT, esta sección se mostrará vacía en producción.
        </p>
      </div>

    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "fastco · Bestsellers",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Texto de la sección"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Lo más pedido"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Bestsellers HORECA."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Subtítulo",
      "default": "Los productos que más rotan en restaurantes, cafeterías y hoteles. Marcas líderes con respaldo, presentación institucional, entrega 48h."
    },
    {
      "type": "header",
      "content": "Productos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección",
      "info": "Elige la colección de la que se mostrarán productos."
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Cantidad de productos a mostrar",
      "min": 4,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar enlace 'Ver todos'",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "fastco · Bestsellers"
    }
  ]
}
{% endschema %}
