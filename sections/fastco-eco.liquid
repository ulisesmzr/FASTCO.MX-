{%- comment -%}
  ─────────────────────────────────────────
  fastco-eco.liquid
  Línea biodegradable y de bajo impacto.
  Diferenciador suave. Lee productos de colección
  configurable (default: tag 'eco').
  NO se activa en home Sprint 1 — solo committed.
  Sprint 2026-05-08.
  ─────────────────────────────────────────
{%- endcomment -%}

{{ 'section-fastco-eco.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign coll = section.settings.collection
  assign limit = section.settings.product_count | default: 4
-%}

<section class="fastco-eco" data-section-id="{{ section.id }}">
  <div class="fastco-eco-blur" aria-hidden="true"></div>
  <div class="fastco-eco-inner">

    <div class="fastco-eco-grid">

      {%- comment -%} LEFT — Header + criterios {%- endcomment -%}
      <div class="fastco-eco-text">
        {%- if section.settings.eyebrow != blank -%}
          <div class="fastco-section-eyebrow fastco-eco-eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2 class="fastco-section-title">{{ section.settings.title }}</h2>
        {%- endif -%}

        {%- if section.settings.lead != blank -%}
          <p class="fastco-section-lead">{{ section.settings.lead }}</p>
        {%- endif -%}

        <ul class="fastco-eco-criteria">
          <li class="fastco-eco-criterion">
            <span class="fastco-eco-criterion-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2v6M12 22v-6M4.93 4.93l4.24 4.24M14.83 14.83l4.24 4.24M2 12h6M22 12h-6M4.93 19.07l4.24-4.24M14.83 9.17l4.24-4.24"/>
              </svg>
            </span>
            <div class="fastco-eco-criterion-text">
              <span class="fastco-eco-criterion-name">Biodegradable certificado</span>
              <span class="fastco-eco-criterion-desc">Se descompone naturalmente en condiciones de compostaje industrial.</span>
            </div>
          </li>

          <li class="fastco-eco-criterion">
            <span class="fastco-eco-criterion-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
                <path d="M9 12l2 2 4-4"/>
              </svg>
            </span>
            <div class="fastco-eco-criterion-text">
              <span class="fastco-eco-criterion-name">Reciclable o reusable</span>
              <span class="fastco-eco-criterion-desc">Diseñado para integrarse a cadenas de reciclaje estándar o reutilizarse.</span>
            </div>
          </li>

          <li class="fastco-eco-criterion">
            <span class="fastco-eco-criterion-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
                <path d="M2 21c0-3 1.85-5.36 5.08-6"/>
              </svg>
            </span>
            <div class="fastco-eco-criterion-text">
              <span class="fastco-eco-criterion-name">Origen sustentable</span>
              <span class="fastco-eco-criterion-desc">Materia prima de fuentes con certificación FSC, PEFC o equivalente.</span>
            </div>
          </li>
        </ul>
      </div>

      {%- comment -%} RIGHT — Grid de productos eco {%- endcomment -%}
      <div class="fastco-eco-products">

        {%- if coll != blank and coll.products_count > 0 -%}
          <div class="fastco-eco-grid-products">
            {%- for product in coll.products limit: limit -%}
              <a href="{{ product.url }}" class="fastco-eco-card">
                <div class="fastco-eco-card-media">
                  {%- if product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 480 }}"
                      alt="{{ product.featured_image.alt | escape | default: product.title }}"
                      width="480"
                      height="480"
                      loading="lazy"
                    >
                  {%- else -%}
                    <div class="fastco-eco-card-empty" aria-hidden="true">
                      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="M21 15l-5-5L5 21"/></svg>
                    </div>
                  {%- endif -%}
                  <span class="fastco-eco-card-tag">Eco</span>
                </div>
                <div class="fastco-eco-card-body">
                  {%- if product.vendor != blank -%}
                    <span class="fastco-eco-card-vendor">{{ product.vendor }}</span>
                  {%- endif -%}
                  <h3 class="fastco-eco-card-title">{{ product.title }}</h3>
                  <span class="fastco-eco-card-price">{{ product.price | money_with_currency }}</span>
                </div>
              </a>
            {%- endfor -%}
          </div>

          {%- if section.settings.show_view_all and coll != blank -%}
            <div class="fastco-eco-foot">
              <a href="{{ coll.url }}" class="fastco-btn fastco-btn--ghost-dark">
                Ver toda la línea eco
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
              </a>
            </div>
          {%- endif -%}

        {%- else -%}

          {%- comment -%} Estado "próximamente" — sin fricción {%- endcomment -%}
          <div class="fastco-eco-soon">
            <div class="fastco-eco-soon-icon">
              <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/>
                <path d="M2 21c0-3 1.85-5.36 5.08-6"/>
              </svg>
            </div>
            <h3 class="fastco-eco-soon-title">Línea eco en preparación</h3>
            <p class="fastco-eco-soon-desc">Estamos curando la selección de productos biodegradables, reciclables y de origen sustentable. Disponibles próximamente en el catálogo.</p>
          </div>

        {%- endif -%}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "fastco · Eco",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "Texto principal"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Línea biodegradable"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Productos eco con respaldo real."
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Subtítulo",
      "default": "Curaduría de productos institucionales con certificaciones de sostenibilidad. Para hoteles, restaurantes y oficinas que comunican un compromiso operativo con el bajo impacto."
    },
    {
      "type": "header",
      "content": "Productos"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Colección eco",
      "info": "Asigna una colección con productos taggeados como 'eco'. Si está vacía, la sección muestra estado 'próximamente'."
    },
    {
      "type": "range",
      "id": "product_count",
      "label": "Cantidad de productos a mostrar",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "checkbox",
      "id": "show_view_all",
      "label": "Mostrar enlace 'Ver toda la línea eco'",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "fastco · Eco"
    }
  ]
}
{% endschema %}
